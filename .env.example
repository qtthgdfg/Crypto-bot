# ================================================================
#  PRO TRADING BOT v3.0 — Environment Configuration
#  cp .env.example .env  then fill in every value before running.
#  NEVER commit .env to version control.
# ================================================================

# ── Binance API credentials ──────────────────────────────────────
# Create at https://www.binance.com/en/my/settings/api-management
# Paper mode : read-only keys (no trading permission needed)
# Live mode  : enable "Spot & Margin Trading" ONLY
#              Whitelist this server's IP for extra security
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_SECRET=YOUR_BINANCE_SECRET_HERE

# ── Telegram bot ─────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy token
# 2. Send any message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the numeric "id" field from the "chat" object
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ── Runtime ───────────────────────────────────────────────────────
# "paper" = learn + signal only (never touches real money)
# "live"  = real orders  (only switch after 🎓 LIVE READY alert)
BOT_MODE=paper

# ── Capital ───────────────────────────────────────────────────────
# Paper-mode starting balance in USD (can be $1)
STARTING_CAPITAL_USD=1.0

# ── Sizing / compounding ─────────────────────────────────────────
# Quarter-Kelly multiplier — 0.25 is the safe standard
KELLY_FRACTION=0.25
# Hard cap: max fraction of capital per single trade
MAX_TRADE_SIZE_PCT=0.10

# ── Scanner ───────────────────────────────────────────────────────
MAX_ACTIVE_SYMBOLS=15
# Minimum 24-h USDT volume to include a coin
MIN_VOLUME_USD=2000000

# ── Live-readiness thresholds ────────────────────────────────────
MIN_TRADES_FOR_LIVE=50
LIVE_READY_WIN_RATE=0.54
LIVE_READY_PROFIT_FACTOR=1.5

# ── Risk management ───────────────────────────────────────────────
# Daily loss cap as a fraction of current capital (5%)
MAX_DAILY_LOSS_PCT=0.05
# Drawdown circuit-breaker (15%)
MAX_DRAWDOWN_PCT=0.15

# ── Signal quality filters ────────────────────────────────────────
MIN_CONFIDENCE=0.76
MIN_RISK_REWARD=2.0

# ── Database ──────────────────────────────────────────────────────
DB_PATH=pro_bot.db

# ── Logging ───────────────────────────────────────────────────────
# Options: error | warn | info | debug | trace
RUST_LOG=info
